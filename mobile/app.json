{
  "expo": {
    "name": "دروب",
    "slug": "droob",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "scheme": "droob",
    "userInterfaceStyle": "automatic",
    "locales": {
      "ar": "./assets/locales/ar.json",
      "en": "./assets/locales/en.json"
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A4F8A",
      "dark": {
        "backgroundColor": "#0F2B4C"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "jo.droob.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "دروب يحتاج موقعك لإظهار أقرب محطات الباص واقتراح الخطوط المناسبة",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "دروب يستخدم موقعك في الخلفية لتنبيهك عند اقتراب محطتك",
        "CFBundleLocalizations": [
          "ar",
          "en",
          "ar",
          "en"
        ],
        "CFBundleDevelopmentRegion": "ar_JO",
        "LSRequiresIPhoneOS": true
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A4F8A"
      },
      "package": "jo.droob.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "config": {}
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "locales": {
        "ar": "./assets/locales/ar.json",
        "en": "./assets/locales/en.json"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "دروب يستخدم موقعك لمساعدتك في التنقل",
          "locationWhenInUsePermission": "دروب يحتاج موقعك لإظهار أقرب المحطات"
        }
      ],
      [
        "expo-localization",
        {
          "locales": [
            "ar",
            "en"
          ]
        }
      ],
      "expo-font"
    ],
    "extra": {
      "API_URL": "${API_URL:-http://localhost:3000}",
      "MAPBOX_ACCESS_TOKEN": "${MAPBOX_ACCESS_TOKEN:-pk.test}",
      "e2e": false,
      "eas": {
        "projectId": "c0f99c6c-f68d-41ee-a9fe-cb99fc6f5baf"
      }
    },
    "owner": "jad_dev",
    "updates": {
      "url": "https://u.expo.dev/c0f99c6c-f68d-41ee-a9fe-cb99fc6f5baf"
    }
  }
}
