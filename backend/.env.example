# دروب Droob — Environment Variables
# Copy this file to .env and fill in your values

# ---- Database (PostgreSQL + PostGIS) ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/droob

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=change-me-to-a-secure-random-string-64-chars-min
JWT_REFRESH_SECRET=change-me-another-secure-random-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Mapbox ----
MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# ---- Firebase (for mobile auth) ----
FIREBASE_PROJECT_ID=droob-jordan
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@droob-jordan.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# ---- Server ----
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ---- Rate Limiting ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---- Sentry ----
SENTRY_DSN=https://...

# ---- GTFS Feed ----
GAM_GTFS_URL=https://gtfs.gam.gov.jo/feed.zip

# ---- Redis Cache TTLs (seconds) ----
REDIS_VEHICLE_POSITION_TTL=30
REDIS_STOP_DEPARTURES_TTL=30
REDIS_ROUTE_CACHE_TTL=300

# ---- Admin ----
ADMIN_EMAILS=admin@droob.jo