{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@db/*": ["./drizzle/*"]
    }
  },
  "include": ["src/**/*.ts", "drizzle/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/check-geom.ts", "src/fix-geometries.ts", "src/data/seed-transit-data.ts", "drizzle/seed-unified.ts", "src/services/push-notifications.ts", "src/services/payment.ts"]
}