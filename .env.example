# ═══════════════════════════════════════════════════════
# دروب Droob — Jordan Transit App
# Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this to .env and fill in your values
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ──── Server ────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ──── Database (PostgreSQL + PostGIS) ────
DATABASE_URL=postgresql://droob:droob_password@localhost:5432/droob
# For Railway/Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/droob

# ──── Redis ────
REDIS_URL=redis://localhost:6379

# ──── JWT Auth ────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ──── Email (SMTP — Nodemailer) ────
# For development: use Gmail SMTP with App Password
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="دروب Droob <noreply@droob.app>"

# ──── Mapbox ────
MAPBOX_ACCESS_TOKEN=pk.eyJ1...
MAPBOX_STYLE_URL=mapbox://styles/droob/clxxxxxx

# ──── CORS ────
CORS_ORIGIN=https://app.droob.jo,https://admin.droob.jo
# In development: CORS_ORIGIN=*

# ──── Rate Limiting ────
RATE_LIMIT_MAX=100

# ──── GTFS Feed (Greater Amman Municipality) ────
GAM_GTFS_URL=https://gtfs.gam.gov.jo/feed.zip

# ──── OSRM Routing Engine ────
OSRM_BASE_URL=http://localhost:5000

# ──── Sentry (Error Tracking) ────
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# ──── Firebase (for mobile push notifications) ────
FIREBASE_PROJECT_ID=droob-jordan
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ──── S3 / R2 Storage (for GTFS files, user uploads) ────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=droob-data

# ──── Payment Gateway (mada + Visa/MC) ────
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_SANDBOX=true

# ──── PostHog Analytics ────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ──── Jordan-Specific ────
DEFAULT_LANGUAGE=ar
TIMEZONE=Asia/Amman
CURRENCY=JOD
FRIDAY_PRAYER_GAP_START=11:30
FRIDAY_PRAYER_GAP_END=13:30